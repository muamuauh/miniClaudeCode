# Copy to `.env` and fill in.
#
# Loading order:
#   1. ./.env                       (project, this file)
#   2. ~/.miniclaudecode/.env       (user-global)
# Shell-exported env vars always win over .env values.
#
# ============================================================================
# Quick start: any LLM, just one (base_url, api_key, model) triple
# ============================================================================
# Set these three and you're done. Works with ANY OpenAI-compatible endpoint:
# DeepSeek, OpenRouter, SiliconFlow, Moonshot, vLLM, Ollama, your own proxy,
# whatever. No need to touch settings.json or pick a profile.
#
LLM_BASE_URL=https://api.deepseek.com/v1
LLM_API_KEY=sk-replace-me
LLM_MODEL=deepseek-chat
# LLM_PROVIDER=openai            # default; set to "anthropic" to use the native SDK

# ============================================================================
# Optional: named profiles in settings.json
# ============================================================================
# If you want to switch between several presets without rewriting .env each
# time, declare them in `.miniclaudecode/settings.json` and select with
# `--profile <name>`. Profiles can either:
#   - read the api key from an env var declared by `api_key_env`, or
#   - inline `"api_key": "sk-..."` directly (self-contained, no .env)
#
# Drop in whatever env var names your profiles reference. Only the ones for
# profiles you actually use need to be set.

# Built-in defaults (used when api_key_env is omitted):
ANTHROPIC_API_KEY=
OPENAI_API_KEY=

# Examples for the bundled profiles in `.miniclaudecode/settings.json`:
DEEPSEEK_API_KEY=
OPENROUTER_API_KEY=
SILICONFLOW_API_KEY=
MOONSHOT_API_KEY=
OLLAMA_API_KEY=ollama          # Ollama doesn't check the value but the SDK requires non-empty
